# ── App ─────────────────────────────────────────────────────────────
APP_NAME=Anisubarr
DEBUG=false

# ── JWT (generate a long random secret for production) ───────────────
JWT_SECRET=change-me-to-something-random
JWT_EXPIRE_MINUTES=10080   # 7 days

# ── Sonarr ───────────────────────────────────────────────────────────
SONARR_HOST=192.168.1.149:8989
SONARR_API_KEY=your_sonarr_api_key_here

# ── Ollama ───────────────────────────────────────────────────────────
OLLAMA_HOST=192.168.1.111:11434
OLLAMA_MODEL_TRANSLATE=qwen2.5:14b
OLLAMA_MODEL_AGENT=qwen2.5:1.5b

# ── SMB / Media ──────────────────────────────────────────────────────
SMB_HOST=192.168.1.149
SMB_USERNAME=
SMB_PASSWORD=

# ── Path mapping (Sonarr path → locally accessible path) ─────────────
# Sonarr always returns its own internal paths, e.g. /data/media/...
# You need to tell Anisubarr how to reach those files from its own process.
#
#   Windows dev (SMB):
#     PATH_SONARR_PREFIX=/data
#     PATH_LOCAL_PREFIX=\\192.168.1.149\data
#     (set SMB_USERNAME/PASSWORD if the share requires auth)
#
#   Docker on Unraid (volume mount):
#     PATH_SONARR_PREFIX=/data
#     PATH_LOCAL_PREFIX=/media
#     (mount the share as:  - /mnt/user:/media:rw  in docker-compose)
#
PATH_SONARR_PREFIX=/data
PATH_LOCAL_PREFIX=\\192.168.1.149\data

# ── FFmpeg ───────────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ── Subtitle scrapers ────────────────────────────────────────────────
HIYORI_USERNAME=
HIYORI_PASSWORD=
HNS_USERNAME=
HNS_PASSWORD=

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./anisubarr.db
