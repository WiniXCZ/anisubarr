# ═══════════════════════════════════════════════════════════════════
# Anisubarr — kompletní přehled všech konfiguračních proměnných
# Zkopíruj tento soubor jako backend/.env a uprav hodnoty
# ═══════════════════════════════════════════════════════════════════

# ── Aplikace ──────────────────────────────────────────────────────
APP_NAME=Anisubarr
JWT_SECRET=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./anisubarr.db

# ── Sonarr ────────────────────────────────────────────────────────
SONARR_HOST=http://192.168.1.x:8989
SONARR_API_KEY=

# ── Mapování cest (Sonarr → lokální přístup) ──────────────────────
# Windows dev / SMB:
#   PATH_SONARR_PREFIX=/data
#   PATH_LOCAL_PREFIX=\\\\server\\data
# Docker / Linux:
#   PATH_SONARR_PREFIX=/data
#   PATH_LOCAL_PREFIX=/media
PATH_SONARR_PREFIX=/data
PATH_LOCAL_PREFIX=

# ── SMB ───────────────────────────────────────────────────────────
SMB_HOST=192.168.1.x
SMB_USERNAME=
SMB_PASSWORD=

# ── Media ─────────────────────────────────────────────────────────
MEDIA_ROOT=\\\\server\\data\\media

# ── Titulky — Hiyori ──────────────────────────────────────────────
HIYORI_USERNAME=
HIYORI_PASSWORD=

# ── Titulky — HnS ─────────────────────────────────────────────────
HNS_USERNAME=
HNS_PASSWORD=

# ── Seerr (dříve Overseerr / Jellyseerr) ─────────────────────────
SEERR_HOST=http://192.168.1.x:5055
SEERR_API_KEY=

# ── Emby / Jellyfin ───────────────────────────────────────────────
EMBY_HOST=http://192.168.1.x:8096
EMBY_API_KEY=
EMBY_EXTERNAL_URL=https://emby.mojadomena.cz

# ── Ollama (AI překladač titulků) ─────────────────────────────────
OLLAMA_HOST=http://192.168.1.x:11434

# ── Webhooks ──────────────────────────────────────────────────────
# Nepovinný secret token pro ověření Sonarr webhooků
# Nastav stejný token v Sonarr: Settings → Connect → Webhook → URL: …?token=<secret>
WEBHOOK_SECRET=

# ── FFmpeg ────────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
